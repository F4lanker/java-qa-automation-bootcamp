{
  "$schema": "https://json-schema.org",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "userId",
      "id",
      "title",
      "body"
    ],
    "properties": {
      "userId": {
        "type": "integer",
        "minimum": 1
      },
      "id": {
        "type": "integer",
        "minimum": 1
      },
      "title": {
        "type": "string",
        "minimum": 1
      },
      "body": {
        "type": "string"
      }
    }
  }
}